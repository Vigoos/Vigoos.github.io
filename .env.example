[TEMPLATE]
# ============================================
# Web3Forms - Configuración del formulario
# ============================================
#
# 1. VARIABLE PRIVADA (RECOMENDADA):
#    Se usa en el server route proxy (/api/contact).
#    La key NUNCA se expone al frontend.
#    Requiere deploy con Node.js (NO static).
#
WEB3FORMS_KEY=your_web3forms_access_key_here
#
# 2. VARIABLE PÚBLICA (FALLBACK):
#    Solo se usa si el server route no está disponible
#    (ej: GitHub Pages, deploy estático).
#    Web3Forms está diseñado para uso público, pero
#    es mejor usar la variable privada cuando sea posible.
#
NUXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_access_key_here
